{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    {
      "identifier": "fs:allow-read-file",
      "allow": [{ "path": "**/posts/assets/**" }, { "path": "**/Margin/**" }]
    }
  ]
}
